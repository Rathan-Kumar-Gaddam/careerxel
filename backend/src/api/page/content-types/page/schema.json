{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Editable marketing pages rendered by the Next.js frontend"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "kicker": {
      "type": "string"
    },
    "eyebrow": {
      "type": "string"
    },
    "headline": {
      "type": "string",
      "required": true
    },
    "mutedHeadline": {
      "type": "string"
    },
    "primaryCta": {
      "type": "string"
    },
    "secondaryCta": {
      "type": "string"
    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "marketing.feature-card"
    },
    "testimonials": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::testimonial.testimonial",
      "mappedBy": "page"
    },
    "pricingContent": {
      "type": "json"
    },
    "resourcesContent": {
      "type": "json"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}
